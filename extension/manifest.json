{
  "manifest_version": 3,
  "name": "Music List Exporter",
  "version": "1.0.0",
  "description": "Собирает список треков из VK Музыки и Яндекс Музыки в tracks.txt для импорта в Spotify.",
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["https://vk.com/*", "https://music.yandex.ru/*"],
  "action": {
    "default_title": "Экспорт музыки",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://vk.com/*", "https://music.yandex.ru/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
